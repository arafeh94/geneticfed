{
  "cache": {
    "class": "src.app.cache.Cache"
  },
  "data": {
    "dataset": "cifar10",
    "transformer": {
      "refer": "src.apis.transformers.cifar10_rgb"
    },
    "distributor": {
      "class": "src.data.data_distributor.UniqueDistributor",
      "num_clients": 10,
      "min_size": 600,
      "max_size": 600
    }
  },
  "model": {
    "class": "libs.model.cv.cnn.Cifar10Model"
  },
  "trainer_class": {
    "refer": "src.federated.components.trainers.CPUTrainer"
  },
  "aggregator": {
    "class": "src.federated.components.aggregators.AVGAggregator"
  },
  "epochs": 50,
  "lr": 0.0001,
  "rounds": 2,
  "batch_size": 50,
  "client_ratio": 0.4,
  "device": "cpu",
  "optimizer": "sgd",
  "criterion": "cel"
}